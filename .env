NODE_ENV=development # can be production, development, test

# Auto convern to string
PORT=3000
HOST_NAME=localhost
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173

# SQL Server configuration
# Always turn on TCP/IP in SQL Server Configuration Manager and set port for SQL Server (default is 1433)
# For SQL Server Express, you also need to set instance name (default is SQLEXPRESS) in database.js
# For SQL Server Standard/Enterprise, you can leave instance name empty and just use port 1433
SQL_USER=sa # change to your SQL Server username
SQL_PASSWORD=kekwisfun # change to your SQL Server password
SQL_SERVER=localhost # change to your server name
SQL_DATABASE=DMS_web # change to your database name
SQL_PORT=1433 # default port for SQL Server, change if you use different port
SQL_ENCRYPT=false # set to true if you want to use encrypted connection (requires SSL certificate)
SQL_TRUST_SERVER_CERTIFICATE=true # set to true if you want to trust server certificate (useful for development, not recommended for production)
SQL_DOMAIN= # set to your domain if using Windows Authentication, leave empty for SQL Authentication

# JWT configuration
JWT_SECRET=your_jwt_secret_key

# config working hours and days for anomaly detection
WORKING_HOUR_START=8
WORKING_HOUR_END=18

# config working days (1-7, where 1 is Monday and 7 is Sunday)
WORKING_DAY_START=1
WORKING_DAY_END=5

# config violation threshold for anomaly detection (e.g. 3 violations within 10 minutes will trigger critical anomaly log)
VIOLATION_THRESHOLD=3

# config dynamic Z-score threshold for anomaly detection (usually 2.5 or 3)
DYNAMIC_Z_THRESHOLD=3