    <table class="table-container">
        <tr>
            <th>ID</th>
            <th>User name</th>
            <th>Email</th>
            <th>Password</th>
            <th>Access</th>
            <th>Action</th>
        </tr>
        <% users.forEach(function(user) { %>
            <tr>
                <td>
                    <%= user.user_id %>
                </td>
                <td>
                    <%= user.username %>
                </td>
                <td>
                    <%= user.email %>
                </td>
                <td>
                    <%= user.password %>
                </td>
                <td>
                    <%= user.access %>
                </td>
                <td>
                    <button><a href="#Edit">Edit</a></button>
                    <button><a href="#Delete">Delete</a></button>
                </td>
            </tr>

            <% }); %>

    </table>

</body>

