<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Audit Log</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <link rel="stylesheet" href="/css/table.css">
    <link rel="stylesheet" href="/css/auditLog.css">
</head>

<body>
    <%- include('../partials/navbar') %>

        <section class="background-content">
            <div class="main-content">
                <div class="title-wrapper">
                    <div class="title">
                        <i class='bx bx-history'></i>
                        <span class="text">System Audit Logs</span>
                    </div>
                    <div class="log-filters">
                        <select class="filter-select">
                            <option value="">All Actions</option>
                            <option value="LOGIN">Login</option>
                            <option value="UPLOAD">Upload</option>
                            <option value="DELETE">Delete</option>
                        </select>
                        <button class="btn-export">
                            <i class='bx bx-download'></i>
                            <span>Export CSV</span>
                        </button>
                    </div>
                </div>

                <div class="table-container">
                    <table class="audit-table">
                        <thead>
                            <tr>
                                <th>Timestamp</th>
                                <th>User ID</th>
                                <th>Action & Resource</th>
                                <th>Status</th>
                                <th>Network Info</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <div class="time-cell">
                                        <span class="date">2024-05-20</span>
                                        <span class="time">14:30:05</span>
                                    </div>
                                </td>
                                <td><span class="user-id-tag">#USR-001</span></td>
                                <td>
                                    <div class="action-info">
                                        <span class="action-type">LOGIN</span>
                                        <span class="resource-path">/auth/login</span>
                                    </div>
                                </td>
                                <td><span class="log-status success">Success</span></td>
                                <td>
                                    <div class="network-info">
                                        <span><i class='bx bx-globe'></i> 192.168.1.1</span>
                                        <span class="browser"><i class='bx bxl-chrome'></i> Chrome / Windows</span>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="time-cell">
                                        <span class="date">2024-05-20</span>
                                        <span class="time">15:12:40</span>
                                    </div>
                                </td>
                                <td><span class="user-id-tag">#USR-042</span></td>
                                <td>
                                    <div class="action-info">
                                        <span class="action-type">DELETE</span>
                                        <span class="resource-path">/docs/contract_v2.pdf</span>
                                    </div>
                                </td>
                                <td><span class="log-status failed">Failed</span></td>
                                <td>
                                    <div class="network-info">
                                        <span><i class='bx bx-globe'></i> 172.16.254.1</span>
                                        <span class="browser"><i class='bx bxl-firefox'></i> Firefox / MacOS</span>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
</body>

</html>